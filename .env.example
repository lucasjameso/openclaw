# ============================================================
# OpenClaw Environment Variables
# Copy to .env and fill in real values
# Master credentials live at ~/Forge/.env
# ============================================================

# --- LLM Provider ---
# Anthropic Claude API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# --- Slack Bot (Socket Mode) ---
# Create a Slack app, enable Socket Mode, get these tokens
# See docs/slack-setup.md for step-by-step instructions
SLACK_BOT_TOKEN=xoxb-YOUR_BOT_TOKEN_HERE
SLACK_APP_TOKEN=xapp-YOUR_APP_TOKEN_HERE

# --- Slack Webhooks ---
# Incoming webhook URLs for posting to specific channels
SLACK_WEBHOOK_FORGE_ALERTS=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
SLACK_WEBHOOK_FORGE_CONSOLE=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
SLACK_WEBHOOK_CONTENT_READY=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
SLACK_WEBHOOK_CLAUDE_CODE=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# --- Slack Channel IDs ---
# Used by skills to target specific channels
SLACK_CHANNEL_FORGE_ALERTS=C0XXXXXXXXX
SLACK_CHANNEL_CONTENT_READY=C0XXXXXXXXX
SLACK_CHANNEL_BOOK_LAUNCH=C0XXXXXXXXX
SLACK_CHANNEL_CLAUDE_CODE=C0XXXXXXXXX
SLACK_CHANNEL_N8N_LOGS=C0XXXXXXXXX

# --- n8n Webhook Bridge ---
# Base URL for the n8n instance (Forge runs n8n via PM2)
N8N_BASE_URL=https://n8n.iac-solutions.io
# n8n API key for authenticated webhook calls
N8N_API_KEY=YOUR_N8N_API_KEY_HERE

# --- Cloudflare ---
# Account ID and API token for tunnel management
CF_ACCOUNT_ID=YOUR_CF_ACCOUNT_ID
CF_API_TOKEN=YOUR_CF_API_TOKEN

# --- OpenClaw Settings ---
# Auto-update the container image
OPENCLAW_AUTO_UPDATE=true
